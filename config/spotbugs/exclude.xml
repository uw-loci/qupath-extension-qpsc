<?xml version="1.0" encoding="UTF-8"?>
<FindBugsFilter>
    <!--
        SpotBugs exclusion filter for qupath-extension-qpsc.
        Only exclude well-understood false positives; keep the filter minimal.
    -->

    <!-- JavaFX UI classes: fields are injected by FXML and look uninitialized to SpotBugs -->
    <Match>
        <Bug pattern="UWF_UNWRITTEN_FIELD"/>
        <Class name="~qupath\.ext\.qpsc\.ui\..*"/>
    </Match>

    <!-- JavaFX controllers: @FXML fields appear as unused writes -->
    <Match>
        <Bug pattern="URF_UNREAD_FIELD"/>
        <Class name="~qupath\.ext\.qpsc\.ui\..*"/>
    </Match>

    <!-- Singleton holders using static mutable fields are intentional -->
    <Match>
        <Bug pattern="MS_SHOULD_BE_FINAL"/>
        <Class name="qupath.ext.qpsc.utilities.MicroscopeConfigManager"/>
    </Match>
</FindBugsFilter>
